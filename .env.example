# Copy this file to .env for local Docker Compose runs.
# Never commit a real production secret.

# Local-development JWT secret. Must be at least 32 chars and must NOT contain "change-me-before-production".
JWT_SECRET=nabat-local-dev-jwt-secret-key-min-256-bits-for-local-development-only-123456

# PostgreSQL defaults used by docker-compose.yml and local app runs.
# Docker exposes Postgres on host port 5433 by default to avoid conflicts with
# a locally installed PostgreSQL on 5432. Inside Docker, services still use postgres:5432.
POSTGRES_HOST_PORT=5433
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5433/nabat_db
SPRING_DATASOURCE_USERNAME=nabat_user
SPRING_DATASOURCE_PASSWORD=nabat_password

SERVER_PORT=8080

# Comma-separated allowed CORS origins. Empty means no cross-origin browser requests.
# Example: NABAT_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
NABAT_CORS_ALLOWED_ORIGINS=

